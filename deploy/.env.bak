# ============================================================================
# Marine & Offshore Expert System — Environment Configuration
# ============================================================================
# Copy: cp deploy/.env.example deploy/.env
# Start: ./deploy/start.sh personal

# ── Deployment Mode ───────────────────────────────────────────────────
# personal   — Single user, lenient rate limits, DuckDuckGo search
# enterprise — Internal team, moderate limits, Tavily search
# saas       — Multi-tenant, strict limits, Stripe billing (Phase 3)
DEPLOYMENT_MODE=personal

# ── Feature Flags ─────────────────────────────────────────────────────
# Enable/disable major features (true/false).
# Personal mode: billing=off, web_search=on, deep_research=off
# SaaS mode: billing=on, web_search=on, deep_research=on
FEATURE_BILLING=false
FEATURE_WEB_SEARCH=true
FEATURE_DEEP_RESEARCH=false
FEATURE_MULTI_TENANT=false

# ── Ports ─────────────────────────────────────────────────────────────
M8_PORT=8000
M1_PORT=8007
MEILI_PORT=7700
SEARXNG_PORT=8888
OLLAMA_PORT=11434

# ── Meilisearch ───────────────────────────────────────────────────────
# Master key (optional for personal mode). Set for production.
# MEILI_MASTER_KEY=your-master-key-here

# ── LLM Backend ───────────────────────────────────────────────────────
# Option 1: Local Ollama
#   docker compose -f deploy/docker-compose.yml --profile llm up -d
#   docker exec -it marine-ollama ollama pull deepseek-r1:7b
#   LLM_BASE_URL=http://ollama:11434/v1
#   LLM_API_KEY=not-needed
#   LLM_MODEL=deepseek-r1:7b
#
# Option 2: DeepSeek Cloud API
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_API_KEY=sk-your-deepseek-key
#   LLM_MODEL=deepseek-chat
#
# Option 3: OpenAI API
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-your-openai-key
#   LLM_MODEL=gpt-4o-mini
#
# Option 4: Anthropic Claude
#   LLM_BASE_URL=https://api.anthropic.com/v1
#   LLM_API_KEY=sk-ant-your-key
#   LLM_MODEL=claude-sonnet-4-20250514
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-fd22ed990ebf4c94b5ae11a108ac62ef
LLM_MODEL=deepseek-chat

# ── Web Search Engine ─────────────────────────────────────────────────
# Options: duckduckgo | searxng | tavily | brave | google
WEB_SEARCH_ENGINE=duckduckgo

# Tavily (https://tavily.com — $0.01/query, 1000 free/month)
# TAVILY_API_KEY=tvly-your-key

# Brave Search (https://brave.com/search/api/ — 2000 free/month)
# BRAVE_API_KEY=BSA-your-key

# Google Custom Search (https://console.cloud.google.com — 100 free/day)
# GOOGLE_API_KEY=AIza-your-key
# GOOGLE_CX=your-search-engine-id

# SearXNG URL (only used when WEB_SEARCH_ENGINE=searxng)
# SEARXNG_URL=http://searxng:8080

# ── SMTP (for password reset emails) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER=marine-expert@example.com
# SMTP_PASSWORD=your-app-password

# ── OAuth (for social login) ───────────────────────────────────────────
# M8_BASE_URL=http://localhost:8000
# OAUTH_REDIRECT_BASE=http://localhost:8000
# M6_BASE_URL=http://localhost:3000
# Google: https://console.cloud.google.com/apis/credentials
# OAUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
# Microsoft: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# OAUTH_MICROSOFT_CLIENT_ID=your-client-id
# OAUTH_MICROSOFT_CLIENT_SECRET=your-secret
# WeChat: https://open.weixin.qq.com/
# OAUTH_WECHAT_APP_ID=your-app-id
# OAUTH_WECHAT_APP_SECRET=your-app-secret
